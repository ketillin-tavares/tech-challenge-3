# =============================================================================
# Servico de Vendas (SOAT Fase 3) - variaveis de ambiente
# -----------------------------------------------------------------------------
# Copie para .env e preencha os valores reais. NUNCA versione o .env.
# Lido por src/environment.py (pydantic-settings).
# =============================================================================

# --- Banco de dados (contexto DatabaseSettings, prefixo DATABASE_) -----------
# DSN async do PostgreSQL usado pelo SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://revenda:revenda@localhost:5432/revenda

# --- ACL de validacao de token (contexto AuthSettings) ------------------------
# Validacao do access token: iss + client_id. O registro/login de clientes vive
# no servico de auth (services/auth), apartado deste servico.
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx
# Opcional: se vazio, derivado de COGNITO_ISSUER + /.well-known/jwks.json
JWKS_URL=

# --- Aplicacao (contexto AppSettings) ----------------------------------------
# development | staging | production
ENVIRONMENT=development
# TRACE | DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Servico de Auth (SOAT Fase 3) - variaveis de ambiente
# -----------------------------------------------------------------------------
# Copie para .env e preencha os valores reais. NUNCA versione o .env.
# Lido por src/environment.py (pydantic-settings). Este servico NAO usa banco.
# =============================================================================

# --- Identidade (contexto AuthSettings, Cognito) ------------------------------
# Regiao AWS do User Pool.
AWS_REGION=us-east-1
# Endpoint AWS customizado (emuladores). Deixe VAZIO para usar a AWS real.
AWS_ENDPOINT_URL=
# Credenciais AWS (IAM) com permissao para cognito-idp (SignUp/InitiateAuth/AdminConfirmSignUp).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# IDs do User Pool/App Client criados na AWS.
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Emissor esperado dos JWTs e JWKS (GET /v1/clientes/*). Vazios = derivados
# de AWS_REGION + COGNITO_USER_POOL_ID (padrao para a AWS real).
COGNITO_ISSUER=
JWKS_URL=

# --- CORS (contexto CorsSettings, prefixo CORS_) ------------------------------
# Origens permitidas ao frontend (CSV). Vazio = CORS desabilitado.
CORS_ORIGINS=http://localhost:5173
# Permite credenciais (cookies) nas respostas CORS. Proibido combinar com '*'.
CORS_ALLOW_CREDENTIALS=false

# --- Rate limiting (contexto RateLimitSettings, prefixo RATELIMIT_) -----------
# Contado por IP e POR PROCESSO (premissa: 1 worker uvicorn).
RATELIMIT_ENABLED=true
RATELIMIT_REGISTER=5/minute
RATELIMIT_LOGIN=10/minute
RATELIMIT_CLIENTES=30/minute

# --- Aplicacao (contexto AppSettings) ----------------------------------------
# development | staging | production
ENVIRONMENT=development
# TRACE | DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

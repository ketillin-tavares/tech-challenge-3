# =============================================================================
# Servico de Auth (SOAT Fase 3) - variaveis de ambiente
# -----------------------------------------------------------------------------
# Copie para .env e preencha os valores reais. NUNCA versione o .env.
# Lido por src/environment.py (pydantic-settings). Este servico NAO usa banco.
# =============================================================================

# --- Identidade (contexto AuthSettings, Cognito) ------------------------------
# Regiao AWS do User Pool.
AWS_REGION=us-east-1
# Endpoint AWS customizado (emuladores). Deixe VAZIO para usar a AWS real.
AWS_ENDPOINT_URL=
# Credenciais AWS (IAM) com permissao para cognito-idp (SignUp/InitiateAuth/AdminConfirmSignUp).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# IDs do User Pool/App Client criados na AWS.
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Aplicacao (contexto AppSettings) ----------------------------------------
# development | staging | production
ENVIRONMENT=development
# TRACE | DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
